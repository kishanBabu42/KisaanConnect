<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.KisaanConnect" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>
        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_light_onTertiaryContainer</item>
        <item name="colorError">@color/md_theme_light_error</item>
        <item name="colorOnError">@color/md_theme_light_onError</item>
        <item name="colorErrorContainer">@color/md_theme_light_errorContainer</item>
        <item name="colorOnErrorContainer">@color/md_theme_light_onErrorContainer</item>
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="colorOnBackground">@color/md_theme_light_onBackground</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>
        <item name="colorOutline">@color/md_theme_light_outline</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/md_theme_light_surface</item>
    </style>

    <style name="Theme.KisaanConnect.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_green</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo</item>
        <item name="windowSplashScreenAnimationDuration">800</item>
        <item name="postSplashScreenTheme">@style/Theme.KisaanConnect</item>
    </style>

    <!-- Typography -->
    <style name="TextStyle.Display" parent="TextAppearance.Material3.DisplayMedium">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>
    <style name="TextStyle.Headline" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>
    <style name="TextStyle.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextStyle.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">sans-serif</item>
    </style>
    <style name="TextStyle.Label" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Buttons -->
    <style name="Widget.KisaanConnect.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.KisaanConnect.Button.Secondary" parent="Widget.Material3.Button.TonalButton">
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.KisaanConnect.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">56dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- TextInputLayout -->
    <style name="Widget.KisaanConnect.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <!-- Cards -->
    <style name="Widget.KisaanConnect.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/md_theme_light_outlineVariant</item>
    </style>

    <!-- Chip -->
    <style name="Widget.KisaanConnect.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">12dp</item>
        <item name="chipMinHeight">40dp</item>
    </style>

    <!-- Toolbar -->
    <style name="Widget.KisaanConnect.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextAppearance">@style/TextStyle.Title</item>
        <item name="android:background">@color/md_theme_light_surface</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Tab Layout -->
    <style name="Widget.KisaanConnect.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/brand_green</item>
        <item name="tabSelectedTextColor">@color/brand_green</item>
        <item name="tabTextColor">@color/neutral_500</item>
        <item name="tabIndicatorFullWidth">false</item>
    </style>

    <!-- Circle Shape for ShapeableImageView -->
    <style name="CircleShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Shimmer placeholder -->
    <style name="ShimmerTheme" parent="Theme.KisaanConnect">
        <item name="shimmer_base_alpha">0.85</item>
    </style>

</resources>

    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "mysql": "^2.18.1",
    "nodemailer": "^8.0.9",
